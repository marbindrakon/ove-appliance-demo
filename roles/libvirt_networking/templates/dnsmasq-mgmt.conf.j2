# dnsmasq config for OVE mgmt network DHCP on {{ ovs_bridge_name }}
interface={{ ovs_mgmt_port }}
bind-dynamic
port=0
no-resolv
no-hosts

# DHCP range on mgmt network — only static assignments used; unknown MACs are ignored
dhcp-range=10.10.{{ lab_id | default(0) }}.10,10.10.{{ lab_id | default(0) }}.200,255.255.255.0,infinite
dhcp-ignore=tag:!known

# Bastion static assignment
dhcp-host={{ bastion_mgmt_mac }},{{ bastion_mgmt_ip }},infinite

# OVE node static assignments (trunk0 parent port)
{% for node in _mgmt_dhcp_hosts %}
dhcp-host={{ node.mac }},{{ node.ip }},infinite
{% endfor %}

# DNS server option — point to bastion
dhcp-option=option:dns-server,{{ bastion_mgmt_ip }}

# NTP server option — point to bastion chrony
dhcp-option=option:ntp-server,{{ bastion_mgmt_ip }}
