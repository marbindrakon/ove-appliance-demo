---
# boot-ove-nodes.yml — Boot OVE nodes from ISO via Redfish
# Generated by site.yml — run from this host:
#   ansible-playbook /root/boot-ove-nodes.yml -i /root/ove-redfish-inventory.ini

- name: Boot OVE nodes from ISO via Redfish
  hosts: ove_nodes
  connection: local
  gather_facts: false
  vars:
    redfish_base: "http://localhost:{{ sushy_port }}/redfish/v1/Systems/{% raw %}{{ inventory_hostname }}{% endraw %}"
    redfish_auth:
      user: "{{ sushy_username }}"
      password: "{{ sushy_password }}"
  tasks:
    - name: Insert ISO as virtual media
      ansible.builtin.uri:
        url: "{{ redfish_base }}/VirtualMedia/Cd/Actions/VirtualMedia.InsertMedia"
        method: POST
        url_username: "{{ sushy_username }}"
        url_password: "{{ sushy_password }}"
        force_basic_auth: true
        body_format: json
        body:
          Image: "http://localhost/{{ ove_agent_iso_path | basename }}"
          Inserted: true
        status_code: [200, 204]
      no_log: true

    - name: Set one-time boot from CD
      ansible.builtin.uri:
        url: "{{ redfish_base }}"
        method: PATCH
        url_username: "{{ sushy_username }}"
        url_password: "{{ sushy_password }}"
        force_basic_auth: true
        body_format: json
        body:
          Boot:
            BootSourceOverrideEnabled: "Once"
            BootSourceOverrideTarget: "Cd"
        status_code: [200, 204]
      no_log: true

    - name: Power on
      ansible.builtin.uri:
        url: "{{ redfish_base }}/Actions/ComputerSystem.Reset"
        method: POST
        url_username: "{{ sushy_username }}"
        url_password: "{{ sushy_password }}"
        force_basic_auth: true
        body_format: json
        body:
          ResetType: "On"
        status_code: [200, 204]
      no_log: true
