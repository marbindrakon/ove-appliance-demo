---
# Debug — set to true to disable no_log (e.g., ansible-playbook site.yml -e debug_mode=true)
debug_mode: false

# Infrastructure backend — "openstack" or "libvirt"
infra_backend: "openstack"

# Install method — "ove" for agent ISO boot, "appliance" for factory disk image
install_method: "ove"

# Lab identifier (0-55). Namespaces credential cache, sushy port, and IP address
# scheme. For libvirt, also namespaces OVS bridges, NAT networks, and services.
# Multiple labs can run in parallel on the same controller/KVM host.
lab_id: 0
cache_dir: ".ove-demo-cache/lab-{{ lab_id }}"

# OpenStack connection (only used when infra_backend == "openstack")
cloud_name: "lab-infra"  # Must be set by operator — matches a cloud in clouds.yaml
demo_cloud_name: "{{ project_name }}"  # Auto-created cloud entry scoped to demo project

# External/provider network
external_network: "ext-net"

# Project
project_name: "ove-demo-{{ lookup('password', cache_dir + '/project-suffix chars=ascii_lowercase,digits length=5') }}"
project_domain: "Default"

# Sushy service user
sushy_username: "sushy"
sushy_password: "{{ lookup('password', cache_dir + '/sushy-password chars=ascii_letters,digits length=24') }}"

# SSH key
ssh_key_name: ""  # Must be set by operator

# OpenStack auth URL (needed for sushy-emulator clouds.yaml)
os_auth_url: ""    # Must be set by operator (e.g., https://identity.example.com:5000/v3)
os_region: "RegionOne"  # Must be set by operator — OpenStack region name for sushy-emulator

# Subscription
subscription_type: "cdn"  # "cdn" for Red Hat CDN, "satellite" for Satellite, "none" to skip (cloud images, Alma, CentOS)
satellite_url: ""  # Required when subscription_type == satellite (e.g., http://satellite.example.com)
rh_subscription_org: ""  # Must be set by operator
rh_subscription_activation_key: ""  # Must be set by operator

# Bastion VM
bastion_flavor: "g1.large"
bastion_image: "rhel-9.5"
bastion_disk_gb: 250
bastion_mgmt_ip: "10.10.{{ lab_id | default(0) }}.1"
bastion_console_password: ""  # Optional — enables password login for cloud-user (console/emergency access)

# OCP client binaries installed on bastion (oc, openshift-install)
# Version or channel from mirror.openshift.com — e.g., "stable-4.20", "latest-4.20", "4.20.18"
ocp_clients_version: "stable-4.20"

# OVE node VMs
ove_node_flavor: "g1.4xlarge"
ove_node_count: 4
ove_node_name_prefix: "ove-node"
ove_node_disk_gb: 250
# USB volume is pre-provisioned from the agent ISO — must be >= ISO size (agent ISO is ~41 GB)
ove_usb_volume_gb: 50
# Management IPs for OVE nodes — one per node, reserved via fixed IP on trunk0 parent port
ove_node_mgmt_ips:
  - "10.10.{{ lab_id | default(0) }}.11"
  - "10.10.{{ lab_id | default(0) }}.12"
  - "10.10.{{ lab_id | default(0) }}.13"
  - "10.10.{{ lab_id | default(0) }}.14"

# OVE cluster
ove_master_count: 3  # Number of control plane nodes (1–5); remaining nodes are workers
cluster_name: "ove"
base_domain: "example.com"
api_vip: "10.10.{{ lab_id | default(0) }}.100"
ingress_vip: "10.10.{{ lab_id | default(0) }}.101"

# External DNS forwarders — used by BIND on the bastion and pushed to the bastion mgmt
# interface via per-port DHCP opts to override the subnet-level dns_nameservers (bastion_mgmt_ip).
dns_forwarders:
  - "8.8.8.8"
  - "8.8.4.4"

# Sushy emulator
sushy_blank_image: "sushy-tools-blank-image"
sushy_port: "{{ 8000 + lab_id | default(0) | int }}"

# OVE agent ISO path on the Ansible controller (only used when install_method == "ove")
ove_agent_iso_path: "{{ playbook_dir }}/agent-ove.x86_64.iso"
# Existing Glance image name or ID to use as the agent ISO (optional).
# If set, skips the local ISO upload and uses this image directly. Not deleted on teardown.
ove_agent_glance_image: ""
# Path to an agent ISO already present on the KVM host (libvirt backend only, optional).
# If set, skips the controller transfer and uses the file directly as the node USB image source.
ove_kvm_host_iso_path: ""

# Appliance mode settings (only used when install_method == "appliance")
appliance_ocp_version: "4.20"
appliance_ocp_channel: "stable"
appliance_cpu_arch: "x86_64"
appliance_disk_size_gb: 250
appliance_image_name: "openshift-appliance"
appliance_cdrom_volume_gb: 1
appliance_container_image: "quay.io/redhat-user-workloads/crt-nshift-appliance-tenant/appliance/appliance@sha256:bcdf91c38a030f1ad5c9448d2953192f9e08035b736b5a5c3b94414fad4105a5"
pull_secret: ''  # Must be set by operator — obtain from console.redhat.com
# SSH key for the appliance image is auto-generated on the bastion (cloud-user)
# and read directly by the appliance_image role during the build
# Path to a pre-built appliance.raw on the Ansible controller (optional).
# If set, uploads directly from the controller to Glance, skipping the bastion build.
appliance_image_path: ""
# Existing Glance image name or ID to use as the appliance image (optional).
# If set, skips both the bastion build and any local upload. Not deleted on teardown.
appliance_glance_image: ""
# Path to a pre-built appliance.raw already present on the KVM host (libvirt backend only, optional).
# If set, skips the bastion build and any controller transfer; used directly as the node boot image.
appliance_kvm_host_image_path: ""

# Networks
bastion_network_cidr: "10.0.0.0/24"
mgmt_network_cidr: "10.10.{{ lab_id | default(0) }}.0/24"
storage_network_cidr: "10.20.{{ lab_id | default(0) }}.0/24"
workload1_network_cidr: "192.168.10.0/24"
workload2_network_cidr: "192.168.20.0/24"
workload3_network_cidr: "192.168.30.0/24"

# VLAN IDs for trunk sub-ports
mgmt_vlan_id: 10
storage_vlan_id: 20
workload1_vlan_id: 30
workload2_vlan_id: 40
workload3_vlan_id: 50

# Optional MTU settings for OVE node interfaces (omitted from install configs if unset)
# mgmt_mtu: 9000
# storage_mtu: 9000

# Network definitions — used by both site.yml and teardown.yml
demo_networks:
  - name: "{{ project_name }}-bastion"
    cidr: "{{ bastion_network_cidr }}"
    enable_dhcp: true
    port_security_enabled: true
    dns_nameservers: "{{ dns_forwarders }}"
  - name: "{{ project_name }}-mgmt"
    cidr: "{{ mgmt_network_cidr }}"
    enable_dhcp: true
    port_security_enabled: false
    dns_nameservers:
      - "{{ bastion_mgmt_ip }}"
  - name: "{{ project_name }}-storage"
    cidr: "{{ storage_network_cidr }}"
    enable_dhcp: false
    port_security_enabled: false
  - name: "{{ project_name }}-workload1"
    cidr: "{{ workload1_network_cidr }}"
    enable_dhcp: false
    port_security_enabled: false
  - name: "{{ project_name }}-workload2"
    cidr: "{{ workload2_network_cidr }}"
    enable_dhcp: false
    port_security_enabled: false
  - name: "{{ project_name }}-workload3"
    cidr: "{{ workload3_network_cidr }}"
    enable_dhcp: false
    port_security_enabled: false

# --- libvirt backend settings (only used when infra_backend == "libvirt") ---

# KVM host connection
kvm_host: ""              # Must be set by operator — IP or hostname of the KVM host
kvm_host_user: "root"     # SSH user on KVM host
kvm_host_ssh_key: ""      # Path to SSH private key for KVM host (optional, uses ssh-agent if empty)

# libvirt storage (shared across labs on the same KVM host)
libvirt_pool_name: "ove-demo"
libvirt_pool_path: "/var/lib/libvirt/images/ove-demo"

# Bastion RHEL qcow2 image (path on KVM host)
bastion_qcow2_image: ""   # Must be set by operator — e.g., /var/lib/libvirt/images/rhel-9.5.qcow2

# Bastion VM sizing (replaces bastion_flavor for libvirt)
bastion_vcpus: 4
bastion_ram_mb: 8192

# OVE node VM sizing (replaces ove_node_flavor for libvirt)
ove_node_vcpus: 16
ove_node_ram_mb: 65536

# SSH public key content for cloud-init injection (libvirt mode)
ssh_public_key: ""  # Must be set by operator — e.g., contents of ~/.ssh/id_ed25519.pub

# Auto-derived libvirt network and MAC address resources (based on lab_id)
ovs_bridge_name: "br-ove-{{ lab_id }}"
ovs_mgmt_port: "l{{ lab_id }}-mgmt"
ovs_bastion_port: "l{{ lab_id }}-bst"
kvm_host_mgmt_ip: "10.10.{{ lab_id }}.254"
mac_prefix: "52:54:00:{{ '%02x' | format(lab_id | int) }}"
bastion_mgmt_mac: "{{ mac_prefix }}:00:01"
bastion_nat_mac: "52:54:00:00:{{ '%02x' | format(lab_id | int) }}:10"

# Auto-derived libvirt OVS bridge network (portgroups provide persistent VLAN config)
libvirt_ovs_network_name: "ove-ovs-{{ lab_id }}"

# Auto-derived libvirt NAT network resources
libvirt_nat_network_name: "ove-nat-{{ lab_id }}"
libvirt_nat_network_cidr: "192.168.{{ 200 + lab_id | int }}.0/24"
libvirt_nat_gateway_ip: "192.168.{{ 200 + lab_id | int }}.1"
libvirt_nat_bastion_ip: "192.168.{{ 200 + lab_id | int }}.10"
libvirt_nat_bridge_name: "virbr-ove-{{ lab_id }}"

# SSH forwarding port for bastion access via KVM host
bastion_ssh_forward_port: "{{ 2222 + lab_id | int }}"

# Auto-derived service/path names for dnsmasq (mgmt network DHCP)
dnsmasq_service_name: "dnsmasq-ove-{{ lab_id }}-mgmt"
dnsmasq_config_path: "/etc/dnsmasq-ove-{{ lab_id }}-mgmt.conf"
dnsmasq_pid_path: "/run/dnsmasq-ove-{{ lab_id }}-mgmt.pid"

# Auto-derived service/path names for sushy-emulator (libvirt backend)
sushy_service_name: "sushy-ove-{{ lab_id }}"
sushy_config_path: "/root/sushy-ove-{{ lab_id }}.conf"
sushy_htpasswd_path: "/root/sushy-ove-{{ lab_id }}.htpasswd"
