---
# Debug — set to true to disable no_log (e.g., ansible-playbook site.yml -e debug_mode=true)
debug_mode: false

# Install method — "ove" for agent ISO boot, "appliance" for factory disk image
install_method: "ove"

# OpenStack connection
cloud_name: "lab-infra"  # Must be set by operator — matches a cloud in clouds.yaml
demo_cloud_name: "{{ project_name }}"  # Auto-created cloud entry scoped to demo project

# External/provider network
external_network: "ext-net"

# Project
project_name: "ove-demo-{{ lookup('password', '.ove-demo-cache/project-suffix chars=ascii_lowercase,digits length=5') }}"
project_domain: "Default"

# Sushy service user
sushy_username: "sushy"
sushy_password: "{{ lookup('password', '.ove-demo-cache/sushy-password chars=ascii_letters,digits length=24') }}"

# SSH key
ssh_key_name: ""  # Must be set by operator

# OpenStack auth URL (needed for sushy-emulator clouds.yaml)
os_auth_url: ""    # Must be set by operator (e.g., https://identity.example.com:5000/v3)
os_region: "RegionOne"  # Must be set by operator — OpenStack region name for sushy-emulator

# Subscription
subscription_type: "cdn"  # "cdn" for Red Hat CDN, "satellite" for Satellite
satellite_url: ""  # Required when subscription_type == satellite (e.g., http://satellite.example.com)
rh_subscription_org: ""  # Must be set by operator
rh_subscription_activation_key: ""  # Must be set by operator

# Bastion VM
bastion_flavor: "g1.large"
bastion_image: "rhel-9.5"
bastion_disk_gb: 250
bastion_mgmt_ip: "10.10.0.1"

# OVE node VMs
ove_node_flavor: "g1.4xlarge"
ove_node_count: 4
ove_node_name_prefix: "ove-node"
ove_node_disk_gb: 250
# USB volume is pre-provisioned from the agent ISO — must be >= ISO size (agent ISO is ~41 GB)
ove_usb_volume_gb: 50
# Management IPs for OVE nodes — one per node, reserved via fixed IP on trunk0 parent port
ove_node_mgmt_ips:
  - "10.10.0.11"
  - "10.10.0.12"
  - "10.10.0.13"
  - "10.10.0.14"

# OVE cluster DNS
cluster_name: "ove"
base_domain: "example.com"
api_vip: "10.10.0.100"
ingress_vip: "10.10.0.101"

# External DNS forwarders — used by BIND on the bastion and pushed to the bastion mgmt
# interface via per-port DHCP opts to override the subnet-level dns_nameservers (bastion_mgmt_ip).
dns_forwarders:
  - "8.8.8.8"
  - "8.8.4.4"

# Sushy emulator
sushy_blank_image: "sushy-tools-blank-image"
sushy_port: 8000

# OVE agent ISO path on the Ansible controller (only used when install_method == "ove")
ove_agent_iso_path: "{{ playbook_dir }}/agent-ove.x86_64.iso"

# Appliance mode settings (only used when install_method == "appliance")
appliance_ocp_version: "4.20"
appliance_ocp_channel: "stable"
appliance_cpu_arch: "x86_64"
appliance_disk_size_gb: 250
appliance_image_name: "openshift-appliance"
appliance_cdrom_volume_gb: 1
appliance_container_image: "quay.io/redhat-user-workloads/crt-nshift-appliance-tenant/appliance/appliance@sha256:bcdf91c38a030f1ad5c9448d2953192f9e08035b736b5a5c3b94414fad4105a5"
pull_secret: ''  # Must be set by operator — obtain from console.redhat.com
# SSH key for the appliance image is auto-generated on the bastion (cloud-user)
# and read directly by the appliance_image role during the build

# Networks
bastion_network_cidr: "10.0.0.0/24"
mgmt_network_cidr: "10.10.0.0/24"
storage_network_cidr: "10.20.0.0/24"
workload1_network_cidr: "192.168.10.0/24"
workload2_network_cidr: "192.168.20.0/24"
workload3_network_cidr: "192.168.30.0/24"

# VLAN IDs for trunk sub-ports
mgmt_vlan_id: 10
storage_vlan_id: 20
workload1_vlan_id: 30
workload2_vlan_id: 40
workload3_vlan_id: 50

# Network definitions — used by both site.yml and teardown.yml
demo_networks:
  - name: "{{ project_name }}-bastion"
    cidr: "{{ bastion_network_cidr }}"
    enable_dhcp: true
    port_security_enabled: true
    dns_nameservers: "{{ dns_forwarders }}"
  - name: "{{ project_name }}-mgmt"
    cidr: "{{ mgmt_network_cidr }}"
    enable_dhcp: true
    port_security_enabled: false
    dns_nameservers:
      - "{{ bastion_mgmt_ip }}"
  - name: "{{ project_name }}-storage"
    cidr: "{{ storage_network_cidr }}"
    enable_dhcp: false
    port_security_enabled: false
  - name: "{{ project_name }}-workload1"
    cidr: "{{ workload1_network_cidr }}"
    enable_dhcp: false
    port_security_enabled: false
  - name: "{{ project_name }}-workload2"
    cidr: "{{ workload2_network_cidr }}"
    enable_dhcp: false
    port_security_enabled: false
  - name: "{{ project_name }}-workload3"
    cidr: "{{ workload3_network_cidr }}"
    enable_dhcp: false
    port_security_enabled: false
